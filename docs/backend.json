
{
  "entities": {
    "Role": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Role",
      "type": "object",
      "description": "Defines the different roles users can have within the AsistenciaPro CRM system.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" }
      },
      "required": ["id", "name", "description"]
    },
    "UserProfile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "UserProfile",
      "type": "object",
      "description": "Represents a user account within the CRM system.",
      "properties": {
        "id": { "type": "string" },
        "username": { "type": "string" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phoneNumber": { "type": "string" },
        "isActive": { "type": "boolean" },
        "roleId": { "type": "string" },
        "cedula": { "type": "string" }
      },
      "required": ["id", "username", "firstName", "lastName", "email", "isActive", "roleId"]
    },
    "AssistanceCompany": {
      "title": "AssistanceCompany",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "contactPerson": { "type": "string" },
        "contactEmail": { "type": "string", "format": "email" },
        "contactPhone": { "type": "string" }
      },
      "required": ["id", "name"]
    },
    "ClientAccount": {
      "title": "ClientAccount",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "assistanceCompanyId": { "type": "string" },
        "contactPerson": { "type": "string" },
        "contactEmail": { "type": "string", "format": "email" },
        "contactPhone": { "type": "string" }
      },
      "required": ["id", "name", "assistanceCompanyId"]
    },
    "ServiceRequest": {
      "title": "ServiceRequest",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "category": { "type": "string" },
        "companyId": { "type": "string" },
        "accountName": { "type": "string" },
        "status": { "type": "string" },
        "billingStatus": { "type": "string" },
        "insuredName": { "type": "string" },
        "claimNumber": { "type": "string" },
        "address": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "description": { "type": "string" },
        "report": { "type": "string" },
        "accountingNotes": { "type": "string" },
        "requestedAmount": { "type": "number" },
        "approvedAmount": { "type": "number" },
        "invoiceNumber": { "type": "string" },
        "billingConsecutive": { "type": "string" },
        "updatedAt": { "type": "string" }
      },
      "required": ["id", "claimNumber", "status"]
    },
    "InventoryItem": {
      "title": "InventoryItem",
      "type": "object",
      "description": "Represents an item in the warehouse inventory.",
      "properties": {
        "description": { "type": "string" },
        "quantity": { "type": "number" },
        "unitValue": { "type": "number" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "lastModifiedBy": { "type": "string" }
      },
      "required": ["description", "quantity", "unitValue"]
    },
    "PayrollRecord": {
      "title": "PayrollRecord",
      "type": "object",
      "description": "Historativo de pagos de nómina realizados a técnicos.",
      "properties": {
        "id": { "type": "string" },
        "technicianId": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "totalLabor": { "type": "number" },
        "totalExpenses": { "type": "number" },
        "totalAdvances": { "type": "number" },
        "netPaid": { "type": "number" },
        "itemsCount": { "type": "number" }
      },
      "required": ["id", "technicianId", "date", "netPaid"]
    },
    "ChatRoom": {
      "title": "ChatRoom",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string", "enum": ["direct", "group"] },
        "participants": { "type": "array", "items": { "type": "string" } },
        "name": { "type": "string" },
        "lastMessage": { "type": "string" },
        "lastMessageAt": { "type": "string", "format": "date-time" }
      }
    },
    "ChatMessage": {
      "title": "ChatMessage",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "text": { "type": "string" },
        "senderId": { "type": "string" },
        "senderName": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/roles/{roleId}",
        "definition": { "entityName": "Role", "schema": { "$ref": "#/backend/entities/Role" }, "description": "System roles." }
      },
      {
        "path": "/user_profiles/{userProfileId}",
        "definition": { "entityName": "UserProfile", "schema": { "$ref": "#/backend/entities/UserProfile" }, "description": "User profiles." }
      },
      {
        "path": "/inventory/{itemId}",
        "definition": { "entityName": "InventoryItem", "schema": { "$ref": "#/backend/entities/InventoryItem" }, "description": "Warehouse inventory items." }
      },
      {
        "path": "/assistance_companies/{assistanceCompanyId}",
        "definition": { "entityName": "AssistanceCompany", "schema": { "$ref": "#/backend/entities/AssistanceCompany" }, "description": "Assistance companies." }
      },
      {
        "path": "/client_accounts/{clientAccountId}",
        "definition": { "entityName": "ClientAccount", "schema": { "$ref": "#/backend/entities/ClientAccount" }, "description": "Client accounts." }
      },
      {
        "path": "/service_requests/{serviceRequestId}",
        "definition": { "entityName": "ServiceRequest", "schema": { "$ref": "#/backend/entities/ServiceRequest" }, "description": "Service requests." }
      },
      {
        "path": "/payroll_history/{payrollId}",
        "definition": { "entityName": "PayrollRecord", "schema": { "$ref": "#/backend/entities/PayrollRecord" }, "description": "Historical payroll records." }
      },
      {
        "path": "/chats/{chatId}",
        "definition": { "entityName": "ChatRoom", "schema": { "$ref": "#/backend/entities/ChatRoom" }, "description": "Chat rooms." }
      },
      {
        "path": "/chats/{chatId}/messages/{messageId}",
        "definition": { "entityName": "ChatMessage", "schema": { "$ref": "#/backend/entities/ChatMessage" }, "description": "Chat messages." }
      }
    ]
  }
}

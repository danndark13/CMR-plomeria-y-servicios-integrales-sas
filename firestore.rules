rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * ASISTENCIAPRO CRM SECURITY RULES
     * Gestión de identidades, servicios y control de inventario RYS SAS.
     */

    // --- HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function getProfile() {
      // Usamos exists() para prevenir errores de denegación si el documento aún no existe en el caché de reglas
      return exists(/databases/$(database)/documents/user_profiles/$(request.auth.uid)) 
        ? get(/databases/$(database)/documents/user_profiles/$(request.auth.uid)).data 
        : null;
    }

    function hasRole(roleId) {
      let profile = getProfile();
      return isSignedIn() && profile != null && profile.isActive == true && profile.roleId == roleId;
    }

    function isAdmin() {
      return hasRole('Administrador');
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- COLLECTION RULES ---

    match /roles/{roleId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /user_profiles/{userProfileId} {
      // Permitir 'get' y 'list' a cualquier usuario autenticado para que la app pueda mostrar nombres y técnicos
      allow get, list: if isSignedIn();
      allow create: if isSignedIn(); // Permitir creación inicial al loguear
      allow update: if (isAdmin() || (isOwner(userProfileId) && request.resource.data.roleId == resource.data.roleId)) && resource != null;
      allow delete: if isAdmin() && resource != null;
    }

    match /assistance_companies/{companyId} {
      allow get, list: if isSignedIn();
      allow create: if isAdmin();
      allow update, delete: if isAdmin();
    }

    match /client_accounts/{clientAccountId} {
      allow get, list: if isSignedIn();
      allow create: if isAdmin();
      allow update, delete: if isAdmin();
    }

    match /service_requests/{serviceRequestId} {
      allow get, list: if isSignedIn() && (isAdmin() || hasRole('Servicio al Cliente') || hasRole('Contabilidad') || resource.data.assignedTechnicianId == request.auth.uid);
      allow create: if isSignedIn() && (isAdmin() || hasRole('Servicio al Cliente'));
      allow update: if isSignedIn() && (isAdmin() || hasRole('Servicio al Cliente') || (resource.data.assignedTechnicianId == request.auth.uid)) && resource != null;
      allow delete: if isAdmin() && resource != null;
    }

    match /service_requests/{serviceRequestId}/service_notes/{serviceNoteId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (resource.data.authorId == request.auth.uid || isAdmin());
      allow delete: if isAdmin();
    }

    /**
     * @description Gestión de inventario de bodega y técnicos.
     * Permite lectura a todo el personal activo para verificación de stock.
     */
    match /inventory/{itemId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if hasRole('Administrador') || hasRole('Contabilidad');
    }
  }
}

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * ASISTENCIAPRO CRM SECURITY RULES
     */

    function isSignedIn() {
      return request.auth != null;
    }

    function getProfile() {
      return exists(/databases/$(database)/documents/user_profiles/$(request.auth.uid)) 
        ? get(/databases/$(database)/documents/user_profiles/$(request.auth.uid)).data 
        : null;
    }

    function hasRole(roleId) {
      let profile = getProfile();
      return isSignedIn() && profile != null && profile.isActive == true && profile.roleId == roleId;
    }

    function isAdmin() {
      return hasRole('Administrador');
    }

    function isAccounting() {
      return hasRole('Contabilidad');
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    match /roles/{roleId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /user_profiles/{userProfileId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if (isAdmin() || (isOwner(userProfileId) && request.resource.data.roleId == resource.data.roleId)) && resource != null;
      allow delete: if isAdmin() && resource != null;
    }

    match /assistance_companies/{companyId} {
      allow get, list: if isSignedIn();
      allow create: if isAdmin();
      allow update, delete: if isAdmin();
    }

    match /client_accounts/{clientAccountId} {
      allow get, list: if isSignedIn();
      allow create: if isAdmin();
      allow update, delete: if isAdmin();
    }

    match /service_requests/{serviceRequestId} {
      allow get, list: if isSignedIn() && (isAdmin() || hasRole('Servicio al Cliente') || isAccounting() || resource.data.assignedTechnicianId == request.auth.uid);
      allow create: if isSignedIn() && (isAdmin() || hasRole('Servicio al Cliente'));
      allow update: if isSignedIn() && (isAdmin() || hasRole('Servicio al Cliente') || isAccounting() || (resource.data.assignedTechnicianId == request.auth.uid)) && resource != null;
      allow delete: if isAdmin() && resource != null;
    }

    match /service_requests/{serviceRequestId}/service_notes/{serviceNoteId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (resource.data.authorId == request.auth.uid || isAdmin());
      allow delete: if isAdmin();
    }

    match /inventory/{itemId} {
      allow get, list, create, update, delete: if isSignedIn();
    }

    match /payroll_history/{payrollId} {
      allow get, list: if isSignedIn() && (isAdmin() || isAccounting());
      allow create, update: if isSignedIn() && (isAdmin() || isAccounting());
      allow delete: if isAdmin();
    }

    match /chats/{chatId} {
      allow read, write: if isSignedIn() && request.auth.uid in resource.data.participants;
      allow create: if isSignedIn() && request.auth.uid in request.resource.data.participants;
    }

    match /chats/{chatId}/messages/{messageId} {
      allow read, write: if isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
    }
  }
}
